{
  "name": "@agent-talkie/adapter-codex",
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "talkie-codex-adapter": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "pretest": "npm run build -w @agent-talkie/protocol && npm run build -w @agent-talkie/persistence && npm run build -w @agent-talkie/relay && npm run build -w @agent-talkie/supervisor && npm run build -w @agent-talkie/client && npm run build -w @agent-talkie/adapter-stdio",
    "test": "vitest run"
  },
  "dependencies": {
    "@agent-talkie/adapter-stdio": "0.0.0",
    "@agent-talkie/client": "0.0.0",
    "@agent-talkie/protocol": "0.0.0",
    "@agent-talkie/supervisor": "0.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
